{
  "name": "rechnungs-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run start:stable",
    "dev:hot": "node scripts/kill-port.mjs 3000 3001 && rm -rf .next && next dev --hostname 127.0.0.1 --port 3001",
    "dev:reset": "node scripts/kill-port.mjs 3000 3001 && rm -rf .next node_modules/.cache && next dev --hostname 127.0.0.1 --port 3001",
    "start:stable": "node scripts/kill-port.mjs 3000 3001 && rm -rf .next && next build && next start --hostname 127.0.0.1 --port 3001",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.5.0",
    "lucide-react": "^0.510.0",
    "next": "^15.3.1",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.3.1",
    "netlify-cli": "^24.0.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
